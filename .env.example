# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# META WHATSAPP CLOUD API INTEGRATION
# Generate from developer.facebook.com -> My Apps -> WhatsApp -> API Setup
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN="viralyze_token"

# META INSTAGRAM GRAPH API & FACEBOOK GRAPH API
# Long-lived access tokens from professional Facebook Pages connected to Instagram Business
INSTAGRAM_BUSINESS_ACCOUNT_ID=""
FACEBOOK_PAGE_ACCESS_TOKEN=""
FACEBOOK_PAGE_ID=""

# EVOLUTION API ALTERNATIVE (WhatsApp Web Session QR emulation)
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE=""
